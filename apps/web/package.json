{
  "name": "tts-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "node scripts/copy-pdfjs-worker.mjs",
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/copy-pdfjs-worker.mjs",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "create-user": "tsx --env-file=.env scripts/create-user.ts",
    "issue-invite": "tsx --env-file=.env scripts/issue-invite.ts",
    "quota-reset": "tsx --env-file=.env scripts/quota-reset.ts",
    "seed-public-books": "tsx --env-file=.env scripts/seed-public-books.ts",
    "cleanup-existing-sentences": "tsx --env-file=.env scripts/cleanup-existing-sentences.ts"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4",
    "bcryptjs": "^3.0.2",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.1",
    "next": "^15.5.15",
    "otpauth": "^9.4.0",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.13.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4",
    "web-vitals": "^4.2.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
