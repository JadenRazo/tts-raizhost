{
  "name": "tts-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "predev": "node scripts/copy-pdfjs-worker.mjs",
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/copy-pdfjs-worker.mjs",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "create-user": "tsx --env-file=.env scripts/create-user.ts",
    "issue-invite": "tsx --env-file=.env scripts/issue-invite.ts",
    "user-stats": "tsx --env-file=.env scripts/user-stats.ts",
    "quota-reset": "tsx --env-file=.env scripts/quota-reset.ts",
    "seed-public-books": "tsx --env-file=.env scripts/seed-public-books.ts",
    "cleanup-existing-sentences": "tsx --env-file=.env scripts/cleanup-existing-sentences.ts",
    "backfill-chapters": "tsx --env-file=.env scripts/backfill-chapters.ts"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "kokoro-js": "^1.2.1",
    "next": "^15.5.18",
    "otpauth": "^9.5.1",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "web-vitals": "^4.2.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
